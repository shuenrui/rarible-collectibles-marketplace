generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourcePlatform {
  phygitals
  courtyard
  beezie
  collector_crypt
  other
}

enum CategoryL1 {
  pokemon
  sports_cards
  one_piece
  yugioh
  comics
  sealed_products
  other
}

enum ConditionType {
  graded
  raw
  sealed
  unknown
}

enum Grader {
  psa
  bgs
  cgc
  sgc
  fanatics
  alt
  other
  none
}

enum GradeNormalized {
  psa10
  psa9
  psa8
  bgs10
  bgs95
  cgc10
  raw
  sealed
  other
}

enum ListingType {
  fixed_price
  auction
  offer
}

enum ListingStatus {
  active
  sold
  cancelled
  expired
  unknown
}

enum TokenStandard {
  erc721
  erc1155
  spl
  other
}

enum UserActivityType {
  sign_in
  wallet_linked
  wallet_unlinked
  deposit_address_viewed
  buy_on_source_clicked
}

model CollectibleListing {
  id               String          @id @default(uuid())
  sourcePlatform   SourcePlatform
  sourceListingId  String
  sourceItemId     String?
  sourceUrl        String

  title            String
  description      String?
  imageUrl         String
  thumbnailUrl     String?
  images           Json?

  categoryL1       CategoryL1
  categoryL2       String?
  franchise        String?
  setName          String?
  cardNumber       String?
  year             Int?

  conditionType    ConditionType   @default(unknown)
  grader           Grader          @default(none)
  gradeValue       String?
  gradeNormalized  GradeNormalized?
  gradeLabelRaw    String?

  listingType      ListingType     @default(fixed_price)
  priceAmount      Decimal         @db.Decimal(24, 8)
  priceCurrency    String
  priceUsd         Decimal?        @db.Decimal(24, 8)
  lastPriceUpdateAt DateTime

  chainId          Int?
  contractAddress  String?
  tokenId          String?
  tokenStandard    TokenStandard?

  vaulted          Boolean         @default(false)
  redeemable       Boolean         @default(false)
  authProvider     String?

  listingStatus    ListingStatus   @default(active)
  listedAt         DateTime?
  soldAt           DateTime?

  sellerAddress    String?
  sellerHandle     String?
  sellerVerified   Boolean         @default(false)

  syncConfidence   Int             @default(50)
  dataQualityFlags Json?
  rawSourcePayload Json?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  syncedAt         DateTime        @default(now())

  @@unique([sourcePlatform, sourceListingId])
  @@index([categoryL1, gradeNormalized, priceUsd, listingStatus])
  @@index([chainId, contractAddress, tokenId])
}

model UserProfile {
  id          String         @id @default(cuid())
  privyUserId String         @unique
  googleEmail String?
  email       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  wallets     UserWallet[]
  activities  UserActivity[]
}

model UserWallet {
  id               String       @id @default(cuid())
  userId           String
  address          String
  chainType        String
  walletClientType String?
  connectorType    String?
  walletType       String?
  isEmbedded       Boolean      @default(false)
  isLinked         Boolean      @default(true)
  nativeBalance    String?
  usdcBalance      String?
  lastSyncedAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities       UserActivity[]

  @@unique([userId, address])
  @@index([address])
  @@index([userId, chainType])
}

model UserActivity {
  id         String           @id @default(cuid())
  userId     String
  walletId   String?
  type       UserActivityType
  title      String
  details    Json?
  createdAt  DateTime         @default(now())

  user       UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     UserWallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
}
