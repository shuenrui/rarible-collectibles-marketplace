generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourcePlatform {
  phygitals
  courtyard
  beezie
  collector_crypt
  renaiss
  other
}

enum CategoryL1 {
  pokemon
  sports_cards
  one_piece
  yugioh
  comics
  sealed_products
  other
}

enum ConditionType {
  graded
  raw
  sealed
  unknown
}

enum Grader {
  psa
  bgs
  cgc
  sgc
  fanatics
  alt
  other
  none
}

enum GradeNormalized {
  psa10
  psa9
  psa8
  bgs10
  bgs95
  cgc10
  raw
  sealed
  other
}

enum ListingType {
  fixed_price
  auction
  offer
}

enum ListingStatus {
  active
  sold
  cancelled
  expired
  unknown
}

enum TokenStandard {
  erc721
  erc1155
  spl
  other
}

enum UserActivityType {
  sign_in
  wallet_linked
  wallet_unlinked
  deposit_address_viewed
  buy_on_source_clicked
  sell_intent_created
  offer_intent_created
}

enum SellIntentStatus {
  pending
  active
  sold
  cancelled
}

enum OfferIntentStatus {
  pending
  accepted
  rejected
  expired
  cancelled
}

model CollectibleListing {
  id               String          @id @default(uuid())
  sourcePlatform   SourcePlatform
  offerIntents     OfferIntent[]
  sellIntents      SellIntent[]
  wishlistItems    WishlistItem[]
  sourceListingId  String
  sourceItemId     String?
  sourceUrl        String

  title            String
  description      String?
  imageUrl         String
  thumbnailUrl     String?
  images           Json?

  categoryL1       CategoryL1
  categoryL2       String?
  franchise        String?
  setName          String?
  cardNumber       String?
  year             Int?

  conditionType    ConditionType   @default(unknown)
  grader           Grader          @default(none)
  gradeValue       String?
  gradeNormalized  GradeNormalized?
  gradeLabelRaw    String?

  listingType      ListingType     @default(fixed_price)
  priceAmount      Decimal         @db.Decimal(24, 8)
  priceCurrency    String
  priceUsd         Decimal?        @db.Decimal(24, 8)
  lastPriceUpdateAt DateTime

  chainId          Int?
  contractAddress  String?
  tokenId          String?
  tokenStandard    TokenStandard?

  vaulted          Boolean         @default(false)
  redeemable       Boolean         @default(false)
  authProvider     String?

  listingStatus    ListingStatus   @default(active)
  listedAt         DateTime?
  soldAt           DateTime?

  sellerAddress    String?
  sellerHandle     String?
  sellerVerified   Boolean         @default(false)

  syncConfidence   Int             @default(50)
  dataQualityFlags Json?
  rawSourcePayload Json?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  syncedAt         DateTime        @default(now())

  @@unique([sourcePlatform, sourceListingId])
  @@index([categoryL1, gradeNormalized, priceUsd, listingStatus])
  @@index([chainId, contractAddress, tokenId])
}

model UserProfile {
  id          String         @id @default(cuid())
  privyUserId String         @unique
  googleEmail String?
  email       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  wallets      UserWallet[]
  activities   UserActivity[]
  sellIntents   SellIntent[]
  offerIntents  OfferIntent[]
  wishlistItems WishlistItem[]
}

model UserWallet {
  id               String       @id @default(cuid())
  userId           String
  address          String
  chainType        String
  walletClientType String?
  connectorType    String?
  walletType       String?
  isEmbedded       Boolean      @default(false)
  isLinked         Boolean      @default(true)
  nativeBalance    String?
  usdcBalance      String?
  lastSyncedAt     DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities       UserActivity[]
  sellIntents      SellIntent[]

  @@unique([userId, address])
  @@index([address])
  @@index([userId, chainType])
}

model UserActivity {
  id         String           @id @default(cuid())
  userId     String
  walletId   String?
  type       UserActivityType
  title      String
  details    Json?
  createdAt  DateTime         @default(now())

  user       UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet     UserWallet?      @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([walletId, createdAt])
}

model SellIntent {
  id            String           @id @default(cuid())
  userId        String
  walletId      String?
  listingId     String?
  title         String
  imageUrl      String?
  priceAmount   String
  priceCurrency String           @default("USDC")
  status        SellIntentStatus @default(pending)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          UserProfile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet        UserWallet?           @relation(fields: [walletId], references: [id])
  listing       CollectibleListing?   @relation(fields: [listingId], references: [id])

  @@index([userId, status])
  @@index([listingId])
}

model OfferIntent {
  id            String            @id @default(cuid())
  listingId     String
  buyerUserId   String?
  buyerAddress  String
  offerAmount   String
  offerCurrency String            @default("USDC")
  expiresAt     DateTime?
  status        OfferIntentStatus @default(pending)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  listing       CollectibleListing @relation(fields: [listingId], references: [id])
  buyer         UserProfile?       @relation(fields: [buyerUserId], references: [id], onDelete: SetNull)

  @@index([listingId, status])
  @@index([buyerUserId, createdAt])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    UserProfile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing CollectibleListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId, createdAt])
}
